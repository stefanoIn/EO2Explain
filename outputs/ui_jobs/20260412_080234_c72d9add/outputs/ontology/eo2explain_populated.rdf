<owl:NamedIndividual rdf:about="#ad">
  <rdf:type rdf:resource="#Country"/>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ad</hasName>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ad_event">
  <rdf:type rdf:resource="#Event"/>
  <hasCountry rdf:resource="#ad"/>
  <hasRegion rdf:resource="#ad"/>
  <hasAssessment rdf:resource="#ad_assessment"/>
  <hasExplanationTrace rdf:resource="#ad_explanation_trace"/>
  <hasEventId rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ad</hasEventId>
  <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ad</hasName>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ad_assessment">
  <rdf:type rdf:resource="#Assessment"/>
  <hasHazard rdf:resource="#flood_hazard"/>
  <hasClaim rdf:resource="#strong_multisignal_flooding_claim"/>
  <hasSeverity rdf:resource="#severe_severity"/>
  <hasConfidence rdf:resource="#high_confidence"/>
  <hasExposure rdf:resource="#medium_exposure"/>
  <hasConcern rdf:resource="#high_concern"/>
  <hasEvidenceBundle rdf:resource="#ad_evidence_bundle"/>
  <hasClarification rdf:resource="#ad_clarification"/>
  <hasProvenance rdf:resource="#ad_provenance"/>
  <hasClaimLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">strong_multisignal_flooding</hasClaimLabel>
  <hasCaseProfile rdf:datatype="http://www.w3.org/2001/XMLSchema#string">high_priority_event</hasCaseProfile>
  <hasInterpretationMode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">robust</hasInterpretationMode>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ad_explanation_trace">
  <rdf:type rdf:resource="#ExplanationTrace"/>
  <tracesAssessment rdf:resource="#ad_assessment"/>
  <tracesEvidenceBundle rdf:resource="#ad_evidence_bundle"/>
  <tracesClarification rdf:resource="#ad_clarification"/>
  <tracesProvenance rdf:resource="#ad_provenance"/>
  <hasHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ad | severe flood | high</hasHeadline>
  <hasSummary rdf:datatype="http://www.w3.org/2001/XMLSchema#string">claim=strong_multisignal_flooding; concern=high; profile=high_priority_event; caveat=no_major_caveat; clarification=no_clarification; strongest_evidence=none; alternative_claim=no_alternative_claim</hasSummary>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ad_evidence_bundle">
  <rdf:type rdf:resource="#EvidenceBundle"/>
  <hasEvidenceItem rdf:resource="#water_increase_pct"/>
  <hasEvidenceItem rdf:resource="#newly_flooded_area_pct"/>
  <hasEvidenceItem rdf:resource="#ndwi_change"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ad_clarification">
  <rdf:type rdf:resource="#Clarification"/>
  <hasClarificationStatus rdf:datatype="http://www.w3.org/2001/XMLSchema#string">no_clarification</hasClarificationStatus>
  <hasAlternativeClaimLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">no_alternative_claim</hasAlternativeClaimLabel>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ad_provenance">
  <rdf:type rdf:resource="#Provenance"/>
  <hasSourceAgentEntity rdf:resource="#water_agent_entity"/>
  <hasRule rdf:resource="#rule_severe_flood_multisignal_rule"/>
  <hasSourceAgent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">water_agent</hasSourceAgent>
  <hasRuleLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_severe_flood_multisignal</hasRuleLabel>
</owl:NamedIndividual>


</rdf:RDF>
