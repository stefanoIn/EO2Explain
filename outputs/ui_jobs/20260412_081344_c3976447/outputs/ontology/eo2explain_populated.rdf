  <hasAlternativeClaimLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">inconclusive_water_signal</hasAlternativeClaimLabel>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ahr_valley_provenance">
