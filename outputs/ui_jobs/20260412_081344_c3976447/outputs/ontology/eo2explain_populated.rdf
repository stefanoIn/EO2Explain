  <hasHeadline rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ahr Valley | mild flood | medium</hasHeadline>
  <hasSummary rdf:datatype="http://www.w3.org/2001/XMLSchema#string">claim=residual_flood_signal; concern=elevated; profile=cautious_monitoring_case; caveat=residual_observation_window; clarification=clarification_provided; strongest_evidence=newly_flooded_area_pct; alternative_claim=inconclusive_water_signal</hasSummary>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ahr_valley_evidence_bundle">
